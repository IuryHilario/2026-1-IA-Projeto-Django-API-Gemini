DJANGO_SECRET_KEY=troque-esta-chave-em-producao
DEBUG=True

# Use GOOGLE_API_KEY ou GEMINI_API_KEY.
# Crie a chave no Google AI Studio.
GOOGLE_API_KEY=cole_sua_chave_aqui

# Modelo de baixo custo/limite gratuito. Pode trocar se sua conta liberar outro modelo.
GEMINI_MODEL=gemini/gemini-2.5-flash-lite

# Opcional para ambiente de aula.
CREWAI_DISABLE_TELEMETRY=true
