# Copie este arquivo para .env e preencha os valores

# Chave da API do Google Gemini (obrigatório)
GOOGLE_API_KEY=sua_chave_aqui

# Configurações do Django
DJANGO_SECRET_KEY=troque-por-uma-chave-longa-e-aleatoria
DEBUG=True

# Configurações do Gemini (opcional — valores padrão já definidos em settings.py)
GEMINI_MODEL=gemini/gemini-2.5-flash-lite
GEMINI_TEMPERATURE=0.2
GEMINI_MAX_OUTPUT_TOKENS=1500
MAX_CONVERSATION_MESSAGES=12
